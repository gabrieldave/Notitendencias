DATABASE_URL=postgresql://cursor:cursor@ys0ocwcwgso8co0ooko8gc4w:5432/notitendencias
# Generar: openssl rand -hex 32  (mismo valor en Coolify y en Kimi WebBridge)
BRIDGE_API_KEY=
DEEPSEEK_API_KEY=change_me
NEXT_PUBLIC_APP_URL=https://notitendencias.vibesystems.tech
PORT=3015
ADMIN_PASSWORD=change_me_admin_password
# Auth.js (NextAuth v5): generar con `openssl rand -base64 32`
AUTH_SECRET=
# URL canónica pública (ej. https://notitendencias.vibesystems.tech). También se usa como fallback si falta NEXT_PUBLIC_APP_URL.
AUTH_URL=
# Tras proxy inverso (Coolify, etc.): `true` para confiar en Host / X-Forwarded-*.
# AUTH_TRUST_HOST=true
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Login de usuarios: solo Google OAuth (AUTH_GOOGLE_*). Magic link deshabilitado.
# WEBHOOK_URL / APP_ID / AUTH_EMAIL_FROM ya no se usan para auth.
# Correos (minúsculas, separados por coma) que reciben rol `admin` en BD al iniciar sesión (Google o magic link).
ADMIN_EMAILS=
# Deprecado: webhooks de notificación (workflows archivados en n8n). Dejar vacío.
# N8N_WEBHOOK_PUBLISHED_TREND=
# N8N_WEBHOOK_NEWSLETTER=
# N8N_WEBHOOK_ALERTS=

# Retención (script npm run cleanup:retention). Por defecto DRY_RUN=true si no defines DRY_RUN.
# DRY_RUN=false  → aplica borrados/archivados. Ver docs/data-retention.md
# DRY_RUN=
# RAW_PROCESSED_DAYS=30
# RAW_BAD_DAYS=15
# PUBLISHED_ARCHIVE_DAYS=45
# REJECTED_DELETE_DAYS=30
# ARCHIVED_DELETE_DAYS=180
# DRAFT_PENDING_DAYS=30
# APP_EVENTS_DAYS=30
# NEWSLETTER_SENDS_DAYS=90

# Sincronizar workflow X AI Radar en n8n (script npm run n8n:sync-x-radar)
N8N_BASE_URL=https://n8n.vibesystems.tech
N8N_API_KEY=

# X API (solo n8n, no en Next frontend)
# X_BEARER_TOKEN=
# X_API_MAX_POSTS_PER_RUN=50
# X_API_MAX_POSTS_PER_DAY=100
# NOTITENDENCIAS_INGEST_URL=https://notitendencias.iareal.net/api/bridge/ingest

# Panel de consumo X API (n8n → POST /api/admin/usage/runs). Generar: openssl rand -hex 32
USAGE_API_KEY=

# Stripe Payment Link para AI Radar (botón "Suscribirme" en header y CTA en pricing).
# Tras pagar, en Stripe configura URL de éxito ej: https://TU_DOMINIO/mi-radar?bienvenida=1
# NEXT_PUBLIC_STRIPE_RADAR_PAYMENT_LINK=https://buy.stripe.com/...
#
# Webhook: Developers → Webhooks → endpoint POST https://TU_DOMINIO/api/webhooks/stripe
# Evento: checkout.session.completed  ·  Signing secret → STRIPE_WEBHOOK_SECRET
STRIPE_WEBHOOK_SECRET=
# Opcional: validar que el checkout incluya estos price_* (coma separada). Requiere STRIPE_SECRET_KEY.
STRIPE_SECRET_KEY=
# STRIPE_PREMIUM_PRICE_IDS=price_xxx
